# Optional custom names. Vercel Upstash integrations can instead inject
# KV_REST_API_URL and KV_REST_API_TOKEN automatically.
# KV_REST_API_READ_ONLY_TOKEN is intentionally unsupported because sessions require SET/DEL.
MUSIC_AUTH_REDIS_REST_URL=
MUSIC_AUTH_REDIS_REST_TOKEN=

# 32 random bytes encoded as base64 or 64 hexadecimal characters.
MUSIC_AUTH_ENCRYPTION_KEY=

# Local batch-one RTMDet + RTMPose FastAPI base URL. No default is assumed.
VITE_POSTURE_INFERENCE_API_URL=
